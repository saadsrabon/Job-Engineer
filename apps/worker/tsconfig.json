{
  "extends": "../../packages/config/typescript/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "Node16",
    "moduleResolution": "node16",
    "target": "ES2022",
    "esModuleInterop": true,
    "baseUrl": "./",
    "paths": {
      "@jobos/shared": ["../../packages/shared/dist/index"],
      "@jobos/shared/paths": ["../../packages/shared/dist/paths"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
