{
  "manifest_version": 3,
  "name": "JobOS Assistant",
  "version": "0.1.0",
  "description": "Capture jobs from any posting page into your JobOS pipeline",
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobOS"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content/capture.js"],
      "run_at": "document_idle"
    }
  ]
}
