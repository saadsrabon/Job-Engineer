{
  "manifest_version": 3,
  "name": "JobOS Assistant",
  "version": "0.0.1",
  "description": "Capture jobs and auto-fill applications — Phase 3",
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobOS"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:3000/*", "http://localhost:3001/*"]
}
