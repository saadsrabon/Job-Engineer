{
  "name": "jobos",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=\"./apps/*\" --filter=\"./packages/*\"",
    "dev:all": "turbo run dev --filter=\"./apps/*\"",
    "dev:stack": "turbo run dev --filter=\"@jobos/web\" --filter=\"@jobos/api\" --filter=\"@jobos/worker\" --filter=\"@jobos/shared\" --filter=\"@jobos/prompts\" --filter=\"@jobos/utils\" --filter=\"@jobos/database\"",
    "dev:web": "turbo run dev --filter=@jobos/web",
    "dev:api": "turbo run dev --filter=@jobos/api",
    "dev:worker": "turbo run dev --filter=@jobos/worker",
    "dev:landing": "turbo run dev --filter=@jobos/landing",
    "dev:docs": "turbo run dev --filter=@jobos/docs",
    "dev:extension": "turbo run dev --filter=@jobos/browser-extension",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @jobos/database db:generate",
    "db:push": "pnpm --filter @jobos/database db:push",
    "db:migrate": "pnpm --filter @jobos/database db:migrate",
    "db:seed": "pnpm --filter @jobos/database db:seed",
    "db:bootstrap": "pnpm interview:sync && pnpm db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "docker:logs": "docker compose logs -f",
    "env:setup": "node scripts/setup-env.mjs",
    "interview:sync": "node scripts/sync-interview-data.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20"
  }
}
