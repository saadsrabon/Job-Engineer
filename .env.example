# Clerk — app_3GoAYo4XrxwNJNhCDTmckqnXSUT
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# From Clerk Dashboard → Webhooks → Add Endpoint → Signing secret (whsec_...)
# Local URL (use ngrok): https://YOUR-NGROK-ID.ngrok.io/api/v1/auth/webhook
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Postgres (Docker — run: pnpm docker:up)
DATABASE_URL=postgresql://jobos:jobos@localhost:5432/jobos

# Redis (Docker — run: pnpm docker:up)
REDIS_URL=redis://localhost:6379

# AI provider — OpenRouter (default) or any OpenAI-compatible gateway
# Provider: openrouter | custom
AI_PROVIDER=openrouter
# Shared API key (falls back to OPENROUTER_API_KEY for backward compatibility)
AI_API_KEY=
# Custom gateway base URL (required when AI_PROVIDER=custom)
# Example: https://api.hcnsec.cn/v1
AI_BASE_URL=
# Default model for custom gateways (e.g. auto, gpt-4o-mini)
AI_DEFAULT_MODEL=auto
# Max in-flight AI requests per API/worker process (gateway limits vary; hcnsec default ~20)
AI_MAX_CONCURRENCY=5
# Optional per-agent model overrides
# AI_MODEL_RESUME_PARSER=
# AI_MODEL_COVER_LETTER=
# AI_MODEL_JOB_ANALYZER=
# AI_MODEL_ATS_SCORER=
# AI_MODEL_EMAIL_WRITER=
# AI_MODEL_INTERVIEW_COACH=
# AI_MAX_TOKENS_RESUME_PARSER=2048
# AI_MAX_TOKENS_COVER_LETTER=1024
# AI_MAX_TOKENS_JOB_ANALYZER=512
# AI_MAX_TOKENS_ATS_SCORER=512
# AI_MAX_TOKENS_EMAIL_WRITER=512
# AI_MAX_TOKENS_INTERVIEW_COACH=1024

# Legacy OpenRouter-only vars (still supported when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=
# Ignored when AI_PROVIDER=custom — use AI_DEFAULT_MODEL or AI_MODEL_RESUME_PARSER instead
OPENROUTER_RESUME_PARSER_MODEL=
OPENROUTER_RESUME_PARSER_MAX_TOKENS=128

# API
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Comma-separated admin emails for /dashboard/admin (defaults to demo@jobos.app)
ADMIN_EMAILS=

# App URLs
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_LANDING_URL=http://localhost:3002

# Browser extension env is generated into apps/browser-extension/.env via pnpm env:setup
# After loading the unpacked extension, add chrome-extension://<EXTENSION_ID> to Clerk allowed_origins

# Upload storage — relative paths resolve from monorepo root (shared by API + worker)
UPLOAD_DIR=./uploads
