# Clerk — app_3GoAYo4XrxwNJNhCDTmckqnXSUT
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# From Clerk Dashboard → Webhooks → Add Endpoint → Signing secret (whsec_...)
# Local URL (use ngrok): https://YOUR-NGROK-ID.ngrok.io/api/v1/auth/webhook
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Postgres (Docker — run: pnpm docker:up)
DATABASE_URL=postgresql://jobos:jobos@localhost:5432/jobos

# Redis (Docker — run: pnpm docker:up)
REDIS_URL=redis://localhost:6379

# OpenRouter
OPENROUTER_API_KEY=
# Optional: override resume-parser model (e.g. google/gemini-2.0-flash-001)
OPENROUTER_RESUME_PARSER_MODEL=
# Optional: max output tokens for resume parsing (default 128 — fits minimal credit balances)
OPENROUTER_RESUME_PARSER_MAX_TOKENS=128

# API
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Comma-separated admin emails for /dashboard/admin (defaults to demo@jobos.app)
ADMIN_EMAILS=

# App URLs
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_LANDING_URL=http://localhost:3002

# Upload storage — relative paths resolve from monorepo root (shared by API + worker)
UPLOAD_DIR=./uploads
